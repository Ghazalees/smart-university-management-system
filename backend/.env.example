DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,testserver
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SQLITE_DB_PATH=/app/data/db.sqlite3
AI_SERVICE_URL=http://ai-service:9000
AI_SERVICE_API_KEY=replace-with-an-internal-service-key
AI_SERVICE_TIMEOUT_SECONDS=8
AI_CONFIDENCE_THRESHOLD=0.55
AI_RETRIEVAL_STRATEGY=hybrid
LOGIN_MAX_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
LOGIN_THROTTLE_RATE=10/min
TOKEN_THROTTLE_RATE=20/min
PASSWORD_THROTTLE_RATE=5/hour
AI_THROTTLE_RATE=30/min
DJANGO_LOG_LEVEL=INFO
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
SECURE_HSTS_SECONDS=0
ALLOW_DEMO_SEED=0
